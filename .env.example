# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://traffic:traffic@localhost:5432/indian_traffic_signs

# ── YOLO Model ───────────────────────────────────────────
YOLO_WEIGHTS=best.pt
YOLO_DEVICE=cpu
YOLO_CONF_THRESHOLD=0.35
YOLO_IOU_THRESHOLD=0.45
YOLO_IMG_SIZE=640
YOLO_BATCH_SIZE=16

# ── Frame Extraction ────────────────────────────────────
FPS=30
FRAME_STRIDE=1

# ── YouTube Search ───────────────────────────────────────
KEYWORDS_FILE=combinatorial_keywords.txt
MAX_RESULTS_PER_KEYWORD=5
SEARCH_DELAY=1.0

# ── Output ───────────────────────────────────────────────
SAVE_ANNOTATED_FRAMES=true
DELETE_VIDEO_AFTER_PROCESSING=true

# ── Pipeline Workers ─────────────────────────────────────
NUM_WORKERS=2
